{
  "compilerOptions": {
    "target": "esnext",
    "module": "commonjs",
    "lib": ["esnext"],
    "jsx": "react-native",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "declaration": true,
    "outDir": "./build",
    "rootDir": "."
  },
  "include": ["src/**/*", "plugin/**/*"],
  "exclude": ["node_modules", "build"]
}
